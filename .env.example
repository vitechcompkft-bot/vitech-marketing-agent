# ───────────────────────────────────────────────────────────
#  Vitech AI Marketinges Agent — környezeti változók
#  Másold át .env.local-ba és töltsd ki. (.env.local-t SOHA ne commitold!)
# ───────────────────────────────────────────────────────────

# --- Adatforrás ---
# DATA_SOURCE: "mock" | "script" | "api"
#   mock   = kitalált tesztadat (token nélkül fut)                         [ALAP]
#   script = VALÓS adat a Google Ads Scriptbol (live_metrics) — token NÉLKÜL!
#   api    = valódi Google Ads API (developer token + OAuth kell)
DATA_SOURCE=mock
# Régi kapcsoló (visszafelé kompatibilis): ha DATA_SOURCE nincs megadva,
# és USE_MOCK_DATA=false → "api" módot jelent.
USE_MOCK_DATA=true

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# --- Anthropic (Claude) — az Agent agya ---
ANTHROPIC_API_KEY=sk-ant-...
# Döntésekhez/elemzéshez (erős), és gyakori rutinhoz (olcsó):
CLAUDE_MODEL_SMART=claude-opus-4-8
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# --- Google Ads API (USE_MOCK_DATA=false esetén kell) ---
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=
GOOGLE_ADS_REFRESH_TOKEN=
# A hirdető fiók (10 jegyű, kötőjel nélkül), pl. 6829124164
GOOGLE_ADS_CUSTOMER_ID=
# Manager (MCC) fiók, ha van; egyébként hagyd üresen
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# --- Telegram bot (BotFather-től) ---
TELEGRAM_BOT_TOKEN=
# A te chat-azonosítód (a bot @userinfobot-tól vagy az első üzenetből)
TELEGRAM_CHAT_ID=
# Tetszőleges titok a webhook védelmére (te találod ki)
TELEGRAM_WEBHOOK_SECRET=valami-random-titok

# --- Cron / belső védelmek ---
# A Vercel cron és a belső jobok ezt küldik Authorization fejlécben
CRON_SECRET=valami-masik-random-titok

# --- Dashboard jelszavas zár (Basic Auth) ---
# Ha a DASHBOARD_PASSWORD ki van töltve, a teljes dashboardot jelszó védi.
# (Üresen hagyva nincs zár.) A cron/Telegram végpontokat NEM érinti.
DASHBOARD_USER=vitech
DASHBOARD_PASSWORD=

# --- Napi összegzo órája (magyar ido, 0-23) ---
# Luca óránként figyel, de Telegramon csak EKKOR küld napi összegzot. Alap: 19.
DAILY_REPORT_HOUR=19

# --- Alap pénznem ---
CURRENCY=HUF
